<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_medium">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start"
            android:layout_marginBottom="@dimen/spacing_normal"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/black"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/exit_clearance"
            android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_xlarge"
            android:textColor="@color/black"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/corner_radius_normal"
            app:cardElevation="@dimen/card_elevation"
            app:cardBackgroundColor="@color/white"
            app:strokeColor="#EEEEEE"
            app:strokeWidth="1dp"
            android:layout_marginBottom="@dimen/spacing_xlarge">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_large">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/student_details"
                    android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="@dimen/spacing_normal"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvStudentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/loading"
                    android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStudentReg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reg No: ---"
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="@dimen/spacing_large"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginBottom="@dimen/spacing_large"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/visitor_details"
                    android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="@dimen/spacing_normal"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvVisitorName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/loading"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvEntryTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entry Time: --:--"
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmCheckout"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/confirm_exit"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/spacing_normal"
            style="@style/Widget.Material3.Button"
            app:cornerRadius="@dimen/corner_radius_round"
            app:icon="@android:drawable/ic_lock_power_off"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/cancel"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:cornerRadius="@dimen/corner_radius_round"/>

    </LinearLayout>
</ScrollView>