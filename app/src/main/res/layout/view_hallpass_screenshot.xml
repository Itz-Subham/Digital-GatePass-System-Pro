<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/screenshotLayout"
    android:layout_width="400px"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="vertical"
    android:padding="40px"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="OFFICIAL DIGITAL HALLPASS"
        android:textSize="22sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:letterSpacing="0.05" />

    <View
        android:layout_width="match_parent"
        android:layout_height="4px"
        android:layout_marginVertical="24px"
        android:background="@color/purple_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="start">

        <TextView
            android:id="@+id/ssStudentName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Student Name"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ssStudentReg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reg: 123456"
            android:textSize="16sp"
            android:textColor="@color/text_secondary" />

        <View
            android:layout_width="100px"
            android:layout_height="2px"
            android:layout_marginVertical="20px"
            android:background="#DDDDDD" />

        <TextView
            android:id="@+id/ssVisitorName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Visitor: Name"
            android:textSize="14sp"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/ssEntryTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Entered: 10:30 AM"
            android:textSize="14sp"
            android:textColor="@color/black" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:layout_marginVertical="30px"
        android:background="#DDDDDD" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="GUARD: SCAN AT EXIT"
        android:textSize="12sp"
        android:textColor="@color/alert_red"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <ImageView
        android:id="@+id/ssCheckoutQr"
        android:layout_width="220px"
        android:layout_height="220px"
        android:layout_gravity="center"
        android:layout_marginTop="15px"
        android:scaleType="fitCenter" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20px"
        android:gravity="center"
        android:text="Valid for single entry/exit only."
        android:textSize="10sp"
        android:textColor="@color/text_secondary"
        android:alpha="0.8" />

</LinearLayout>